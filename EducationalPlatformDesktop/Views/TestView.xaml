<UserControl x:Class="EducationalPlatformDesktop.Views.TestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EducationalPlatformDesktop.ViewModels"
             Background="#0F172A">
    <UserControl.DataContext>
        <vm:TestViewModel/>
    </UserControl.DataContext>

    <Grid Margin="40">
        <!-- Экран теста -->
        <StackPanel Visibility="{Binding IsFinished, Converter={StaticResource InverseBoolToVis}}">
            <TextBlock Text="{Binding CurrentQuestion.Text}"
                       Foreground="White" FontSize="20" TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <TextBlock Foreground="#9CA3AF" FontSize="13" Margin="0,0,0,16">
                <Run Text="Вопрос "/>
                <Run Text="{Binding QuestionNumber}"/>
                <Run Text=" из "/>
                <Run Text="{Binding TotalQuestions}"/>
            </TextBlock>

            <RadioButton Content="{Binding CurrentQuestion.Options[0]}"
                         Foreground="White" Margin="0,6" FontSize="15"
                         IsChecked="{Binding SelectedOption, Converter={StaticResource EqualConverter}, ConverterParameter=0}"/>
            <RadioButton Content="{Binding CurrentQuestion.Options[1]}"
                         Foreground="White" Margin="0,6" FontSize="15"
                         IsChecked="{Binding SelectedOption, Converter={StaticResource EqualConverter}, ConverterParameter=1}"/>
            <RadioButton Content="{Binding CurrentQuestion.Options[2]}"
                         Foreground="White" Margin="0,6" FontSize="15"
                         IsChecked="{Binding SelectedOption, Converter={StaticResource EqualConverter}, ConverterParameter=2}"/>
            <RadioButton Content="{Binding CurrentQuestion.Options[3]}"
                         Foreground="White" Margin="0,6" FontSize="15"
                         IsChecked="{Binding SelectedOption, Converter={StaticResource EqualConverter}, ConverterParameter=3}"/>

            <Button Content="Ответить" Command="{Binding AnswerCommand}"
                    Width="160" Height="38" Margin="0,24,0,0"
                    HorizontalAlignment="Left"
                    Background="#2563EB" Foreground="White"
                    BorderThickness="0" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Экран результата -->
        <StackPanel Visibility="{Binding IsFinished, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Тест завершён!" Foreground="White"
                       FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Foreground="#86EFAC" FontSize="20"
                       HorizontalAlignment="Center" Margin="0,16">
                <Run Text="Результат: "/>
                <Run Text="{Binding Score}"/>
                <Run Text=" / "/>
                <Run Text="{Binding TotalQuestions}"/>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>