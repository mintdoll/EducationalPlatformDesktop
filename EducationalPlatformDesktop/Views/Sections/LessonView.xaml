<UserControl x:Class="EducationalPlatformDesktop.Views.Sections.LessonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Border Margin="24"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="24">
            <DockPanel LastChildFill="True">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Content="← К курсам"
                            Width="110" Height="36"
                            Command="{Binding BackToCoursesCommand}"
                            Background="{StaticResource SecondaryBackgroundBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1" FontWeight="SemiBold" Cursor="Hand" />

                    <StackPanel Grid.Column="2"
            Orientation="Horizontal">

                        <Button Content="{Binding SelectedLesson.CompletionButtonText}"
            Command="{Binding CompleteLessonCommand}"
            CommandParameter="{Binding SelectedLesson}"
            IsEnabled="{Binding SelectedLesson.CanBeCompleted}"
            Width="175"
            Height="36"
            Margin="0,0,10,0"
            Background="{StaticResource SecondaryBackgroundBrush}"
            Foreground="{StaticResource TextPrimaryBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            FontWeight="SemiBold"
            Cursor="Hand" />

                        <Button Content="Перейти к тесту →"
            Command="{Binding OpenTestCommand}"
            Width="170"
            Height="36"
            Background="{StaticResource AccentBrush}"
            Foreground="White"
            BorderBrush="{StaticResource AccentBorderBrush}"
            BorderThickness="1"
            FontWeight="SemiBold"
            Cursor="Hand" />
                    </StackPanel>
                </Grid>

                <StackPanel>
                    <TextBlock Text="{Binding SelectedLesson.Title}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock Text="{Binding SelectedCourse.Title}"
                               FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,8,0,0" />

                    <TextBlock Text="{Binding SelectedModule.Title}"
                               FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,4,0,20" />

                    <Border Background="#FCFBF8"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="18">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding LessonContent}"
                                       FontSize="15"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="23" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
