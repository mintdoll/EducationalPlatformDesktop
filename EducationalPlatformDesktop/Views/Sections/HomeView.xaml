<UserControl x:Class="EducationalPlatformDesktop.Views.Sections.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock Text="Обзор"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="12"
                       Margin="0,0,0,10" />

            <UniformGrid Columns="3"
                         Margin="0,0,0,18">
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding ActiveCoursesCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Активных курсов"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding LessonsCompletedCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Уроков пройдено"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardStyle}"
                        Margin="0">
                    <StackPanel>
                        <TextBlock Text="{Binding CertificatesCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Сертификат"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="{StaticResource SecondaryBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Добро пожаловать!"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,10" />
                    <TextBlock Text="Здесь доступны курсы, модули, уроки и тексты лекций."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14" />

                    <Border Background="#2B3345"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Быстрый обзор"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="0,0,0,10" />
                            <TextBlock Text="{Binding Profile.FullName, StringFormat=Пользователь: {0}}"
                                       FontSize="13"
                                       Foreground="#D7D7DF"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding Profile.Group, StringFormat=Группа: {0}}"
                                       FontSize="13"
                                       Foreground="#D7D7DF"
                                       Margin="0,0,0,6" />
                            
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
