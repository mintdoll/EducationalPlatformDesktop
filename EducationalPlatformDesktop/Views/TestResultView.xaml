<UserControl x:Class="EducationalPlatformDesktop.Views.TestResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Border MaxWidth="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Padding="32"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">

            <StackPanel>
                <Border Visibility="{Binding DataContext.HasApiStatusMessage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"
                        Background="#FFF7ED"
                        BorderBrush="#FDBA74"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14"
                        Margin="0,0,0,16">
                    <TextBlock Text="{Binding DataContext.ApiStatusMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="#9A3412"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </Border>
                
                <Border Width="72"
                        Height="72"
                        HorizontalAlignment="Center"
                        Background="#EFEDFF"
                        CornerRadius="36">

                    <TextBlock Text="✓"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="34"
                               Foreground="{StaticResource AccentBrush}" />
                </Border>

                    <TextBlock Text="{Binding ResultTitle}"
                               Margin="0,18,0,6"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock Text="{Binding Result.TestTitle}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                <TextBlock Text="{Binding ScoreText}"
                           Margin="0,22,0,4"
                           HorizontalAlignment="Center"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" />

                <TextBlock Text="{Binding AnswersText}"
                           HorizontalAlignment="Center"
                           FontSize="15"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <TextBlock Text="{Binding PassingScoreText}"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}" />

                <TextBlock Text="{Binding CompletedAtText}"
                           Margin="0,4,0,0"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}" />

                <TextBlock Text="{Binding ResultDescription}"
                           Margin="0,20,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <Border Margin="0,20,0,0"
                        Padding="16"
                        Background="{StaticResource SecondaryBackgroundBrush}"
                        CornerRadius="12">

                    <TextBlock Text="{Binding CertificateMessage}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>

                <StackPanel Margin="0,24,0,0"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">

                    <Button Content="К курсам"
                            Command="{Binding BackToCoursesCommand}"
                            Width="140"
                            Height="40"
                            Margin="0,0,12,0"
                            Background="{StaticResource SecondaryBackgroundBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            Cursor="Hand" />

                    <Button Content="Пройти ещё раз"
                            Command="{Binding RetryCommand}"
                            Width="160"
                            Height="40"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            BorderBrush="{StaticResource AccentBorderBrush}"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Cursor="Hand" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>