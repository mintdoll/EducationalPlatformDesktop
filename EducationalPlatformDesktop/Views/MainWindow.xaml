<Window x:Class="EducationalPlatformDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="EducationalPlatform"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Блок с названием -->
                <StackPanel Grid.Row="0" Margin="0,8,0,28">
                    <TextBlock Text="EducationalPlatform"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Демонстрационная оболочка"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               Margin="0,6,0,0" />
                </StackPanel>

                <!-- Навигация -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="ОБУЧЕНИЕ"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,10" />

                        <Button Content="Главная"
                                Command="{Binding ShowHomeCommand}"
                                Style="{StaticResource HomeSidebarButtonStyle}" />

                        <Button Content="Курсы"
                                Command="{Binding ShowCoursesCommand}"
                                Style="{StaticResource CoursesSidebarButtonStyle}" />

                        <Button Content="Прогресс"
                                Command="{Binding ShowProgressCommand}"
                                Style="{StaticResource ProgressSidebarButtonStyle}" />
                        <Button Content="Сертификаты"
                                Command="{Binding ShowCertificatesCommand}"
                                Style="{StaticResource CertificatesSidebarButtonStyle}" />

                        <Button Content="Профиль"
                                Command="{Binding ShowProfileCommand}"
                                Style="{StaticResource ProfileSidebarButtonStyle}" />
                    </StackPanel>

                    <Button Grid.Row="1"
                            VerticalAlignment="Bottom"
                            Content="Выйти"
                            Command="{Binding ExitCommand}"
                            Height="44"
                            Margin="0,20,0,0"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            BorderBrush="{StaticResource AccentBorderBrush}"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Cursor="Hand" />
                </Grid>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1"
              Background="{StaticResource PageBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Верхняя шапка -->
            <Border Grid.Row="0"
                    Background="{StaticResource PageBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="28,22">
                <StackPanel>
                    <TextBlock Text="{Binding PageTitle}"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding PageDescription}"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- Контент разделов -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"
                            Margin="0" />
        </Grid>
    </Grid>
</Window>
